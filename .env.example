# =============================================================================
# UNO Minda API Server — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values before starting the server.
# NEVER commit your actual .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — Server will refuse to start without this
# -----------------------------------------------------------------------------

# A strong, randomly generated API key (minimum 32 characters).
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=your-strong-random-api-key-here-minimum-32-chars

# -----------------------------------------------------------------------------
# CORS — Allowed frontend origins
# -----------------------------------------------------------------------------

# Comma-separated list of allowed origins for CORS.
# Use "*" ONLY for development/testing — never in production.
# Example: ALLOWED_ORIGINS=https://myapp.com,https://staging.myapp.com
ALLOWED_ORIGINS=*

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------

# Max requests per minute for static data endpoints (per IP)
RATE_LIMIT_STATIC=60/minute

# Max requests per minute for live data endpoints (news, stock) (per IP)
# These hit external services so keep this lower
RATE_LIMIT_LIVE=10/minute

# -----------------------------------------------------------------------------
# Cache TTLs
# -----------------------------------------------------------------------------

# How long to cache news results (in seconds). Default: 300 (5 minutes)
CACHE_TTL_NEWS=300

# How long to cache stock data (in seconds). Default: 120 (2 minutes)
CACHE_TTL_STOCK=120

# -----------------------------------------------------------------------------
# Server (local development only — PythonAnywhere ignores HOST/PORT)
# -----------------------------------------------------------------------------

HOST=0.0.0.0
PORT=8000

# Set to "true" to enable Swagger UI at /docs and auto-reload
# IMPORTANT: Set to "false" in production
DEBUG=false

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
